# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cafe_erez_betting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY_MINUTES=60

# OTP
OTP_EXPIRY_MINUTES=5
SMS_PROVIDER=inforu   # inforu | twilio | vonage
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=CafeErez

# External (backend sync only)
WINNER_SYNC_INTERVAL_SECONDS=60
TELESPORT_BASE_URL=https://www.telesport.co.il
LIVEGAMES_BASE_URL=https://www.livegames.co.il

# App
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (Vite)
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000

# NuGet cache path (Windows: uncomment and set to your path)
# NUGET_PACKAGES=C:/Users/YourName/.nuget/packages
